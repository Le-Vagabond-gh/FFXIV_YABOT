    <IsPackable>false</IsPackable>
    <Configurations>Debug;ExportDebug;ExportRelease;Release</Configurations>
    <NoWarn>CS8625;CS8618;CS8602;CS8604;CS8600;CS8603;CS8629;CS0414;CS0169;CS1591</NoWarn>
